# Postgres (banco exclusivo do transaction-service)
TRANSACTION_SERVICE_DB_USER=postgres
TRANSACTION_SERVICE_DB_PASSWORD=postgres
TRANSACTION_SERVICE_DB_PORT=5433

# App
TRANSACTION_SERVICE_PORT=9082
SPRING_PROFILES_ACTIVE=prod

# Spring datasource (host = nome do serviço postgres no docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/postgres?currentSchema=transaction_service
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Kafka (solo: container kafka deste compose | grupo: broker compartilhado na leilao-network)
KAFKA_SERVERS=kafka:29092

# Eureka (solo: desligado | grupo: ligar e apontar para o servidor do grupo)
EUREKA_SERVER_URL=http://eureka:8761/eureka/
EUREKA_CLIENT_REGISTER_WITH_EUREKA=false
EUREKA_CLIENT_FETCH_REGISTRY=false

# Logstash (solo: localhost | grupo: host do ELK na leilao-network)
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000
